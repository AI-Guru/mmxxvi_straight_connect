# Comma-separated list of Telegram account labels
TELEGRAM_ACCOUNTS=bot1,bot2

# Per-account bot tokens (from @BotFather)
# Format: TELEGRAM_<LABEL>_BOT_TOKEN=<token>
TELEGRAM_BOT1_BOT_TOKEN=your-bot1-token-here
TELEGRAM_BOT2_BOT_TOKEN=your-bot2-token-here

# Port
MCP_PORT=9831

# Chat model (used by uv run chat)
OPENAI_API_BASE=http://localhost:8000/v1
OPENAI_API_KEY=not-needed
CHAT_MODEL=openai:your-model-name
