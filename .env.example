# Comma-separated list of Telegram account labels
TELEGRAM_ACCOUNTS=bot1,bot2

# Per-account bot tokens (from @BotFather)
# Format: TELEGRAM_<LABEL>_BOT_TOKEN=<token>
TELEGRAM_BOT1_BOT_TOKEN=your-bot1-token-here
TELEGRAM_BOT2_BOT_TOKEN=your-bot2-token-here

# Telegram tool levels: basic | standard | advanced | full
# Global default (applies to all accounts unless overridden):
TELEGRAM_LEVEL=basic
# Per-account override (optional):
# TELEGRAM_BOT1_LEVEL=standard
# TELEGRAM_BOT2_LEVEL=full
#
# Levels:
#   basic    - get_me, send_message, get_updates
#   standard - basic + forward_message, edit_message_text, delete_message, send_photo, send_document
#   advanced - standard + get_chat, send_location, send_poll, pin/unpin_chat_message, get_chat_member_count, get_chat_member
#   full     - advanced + send_audio, send_video, send_voice, send_sticker, copy_message, set_message_reaction, leave_chat, send_contact, send_venue

# Optional: restrict which chats a bot account can interact with.
# Comma-separated list of chat IDs. If not set, all chats are allowed.
# TELEGRAM_BOT1_ALLOWED_CHATS=123456789,-1001234567890
# TELEGRAM_BOT2_ALLOWED_CHATS=987654321

# Optional: restrict which users a bot account will interact with.
# Comma-separated list of Telegram user IDs. Incoming updates from
# non-listed users are filtered out. If not set, all users are allowed
# (a warning is logged at startup).
# TELEGRAM_BOT1_ALLOWED_USER_IDS=123456789
# TELEGRAM_BOT2_ALLOWED_USER_IDS=123456789,987654321

# Port
MCP_PORT=9831

# Chat model (used by uv run chat)
OPENAI_API_BASE=http://localhost:8000/v1
OPENAI_API_KEY=not-needed
CHAT_MODEL=openai:your-model-name
